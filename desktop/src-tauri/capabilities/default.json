{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core capabilities for the Valori desktop window.",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:17862"]
  },
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "store:default",
    "window-state:default",
    "deep-link:default",
    "allow-start-daemon",
    "allow-stop-daemon",
    "allow-daemon-status",
    "allow-node-health",
    "allow-add-recent-document",
    "allow-install-update",
    "updater:default"
  ]
}
