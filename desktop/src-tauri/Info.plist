<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Register valori:// as a custom URL scheme so the OS routes deep links
       (e.g. valori://projects/my-project) to this app. Tauri merges this file
       with its own generated Info.plist at build time. -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLName</key>
      <string>com.valori.desktop</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>valori</string>
      </array>
    </dict>
  </array>
</dict>
</plist>
