# Node
node_modules/
dist/

# Tauri / Rust build artifacts
src-tauri/target/
# Tauri codegen (schemas, etc.) — regenerated on build
src-tauri/gen/
# Sidecar binaries (valori-daemon, valori-node, node) — generated per-platform
# by scripts/prepare-sidecars.mjs + prepare-ui-server.mjs, never committed.
src-tauri/binaries/
# Bundled ui/ standalone server (Next.js build output), generated by
# scripts/prepare-ui-server.mjs, never committed.
src-tauri/resources/

# NOTE: src-tauri/icons/ is intentionally NOT ignored. tauri.conf.json requires
# those files to exist. Generate once with `npm run icon <path-to-logo.png>`
# and commit them so a fresh clone builds.
